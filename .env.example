# OpenAI (required for chat + embeddings)
OPENAI_API_KEY=your-openai-api-key-here

# Optional — must match the model used when you ran `npm run ingest`
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Retrieval tuning (optional; cosine similarity ~0–1 for normalized embeddings)
# RETRIEVAL_TOP_K=15
# MIN_RETRIEVAL_SCORE=0.22
# If no chunk passes that bar, top chunks above WEAK_RETRIEVAL_MIN are still used (paraphrase help)
# WEAK_RETRIEVAL_MIN=0.15
# WEAK_RETRIEVAL_TOP_K=5
# Keyword overlap boost on top of cosine (helps "visa"/"immigration" match chunk text)
# RETRIEVAL_KEYWORD_BOOST=0.08

# Ingest only (optional)
# CHUNK_SIZE=1200
# CHUNK_OVERLAP=150
