# OpenAI (required for chat + embeddings)
OPENAI_API_KEY=your-openai-api-key-here

# Optional — must match the model used when you ran `npm run ingest`
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Retrieval tuning (optional; cosine similarity 0–1)
# RETRIEVAL_TOP_K=6
# MIN_RETRIEVAL_SCORE=0.28

# Ingest only (optional)
# CHUNK_SIZE=1200
# CHUNK_OVERLAP=150
